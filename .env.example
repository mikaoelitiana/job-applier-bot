# ─── LLM ────────────────────────────────────────────────────────────────────
# Format: <provider>/<model-name>
# Supported providers: anthropic, openai, gemini, ollama, perplexity, openrouter, ollamacloud, minimax, opencode, together
# Examples:
#   anthropic/claude-sonnet-4-0
#   openai/gpt-4o
#   gemini/gemini-flash-latest
#   ollama/llama3.1:8b
#   perplexity/sonar-pro
#   openrouter/google/gemini-2.0-flash-exp
#   ollamacloud/llama3.3:70b
#   minimax/MiniMax-M2.5
#   opencode/minimax-m2.5
#   together/meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8
LLM_MODEL=anthropic/claude-sonnet-4-0

# Optional fallback model used when the primary model returns invalid agent output
# Example: opencode/claude-sonnet-4-5
FALLBACK_LLM_MODEL=

# Set the key for whichever provider you chose above
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=
OLLAMACLOUD_API_KEY=
MINIMAX_API_KEY=
OPENCODE_API_KEY=
TOGETHER_API_KEY=

# ─── TELEGRAM ────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here
TELEGRAM_BOT_TOKEN=

# Optional: restrict the bot to specific Telegram user IDs (comma-separated)
# Find your user ID by messaging @userinfobot on Telegram
# Leave empty to allow any user (not recommended for a personal bot)
ALLOWED_TELEGRAM_USER_IDS=

# ─── GOOGLE SHEETS ───────────────────────────────────────────────────────────
# Option 1: paste the full service account JSON as a single-line string (useful for VPS/CI secrets)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option 2: path to the service account JSON key file (relative to /app inside the container)
# Used only when GOOGLE_SERVICE_ACCOUNT_JSON is not set.
GOOGLE_SERVICE_ACCOUNT_FILE=assets/service_account.json

# The ID from your Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=

# Name of the tab/worksheet to write to (will be created if it doesn't exist)
GOOGLE_SHEET_TAB=Applications

# ─── ASSETS ──────────────────────────────────────────────────────────────────
# Paths are relative to the working directory inside the container (/app)
RESUME_PATH=assets/resume.pdf
PROFILE_PATH=assets/profile.json

# ─── LOGGING ─────────────────────────────────────────────────────────────────
# Log file path inside the container — stored in the assets volume so logs
# survive container restarts and redeployments. Set to empty to disable file logging.
LOG_FILE=/app/assets/applier.log
