# ─── LLM ────────────────────────────────────────────────────────────────────
# Format: <provider>/<model-name>
# Supported providers: anthropic, openai, gemini, ollama
# Examples:
#   anthropic/claude-sonnet-4-0
#   openai/gpt-4o
#   gemini/gemini-flash-latest
#   ollama/llama3.1:8b
LLM_MODEL=anthropic/claude-sonnet-4-0

# Set the key for whichever provider you chose above
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── TELEGRAM ────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here
TELEGRAM_BOT_TOKEN=

# Optional: restrict the bot to specific Telegram user IDs (comma-separated)
# Find your user ID by messaging @userinfobot on Telegram
# Leave empty to allow any user (not recommended for a personal bot)
ALLOWED_TELEGRAM_USER_IDS=

# ─── GOOGLE SHEETS ───────────────────────────────────────────────────────────
# Path to the service account JSON key file (relative to /app inside the container)
GOOGLE_SERVICE_ACCOUNT_FILE=assets/service_account.json

# The ID from your Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=

# Name of the tab/worksheet to write to (will be created if it doesn't exist)
GOOGLE_SHEET_TAB=Applications

# ─── ASSETS ──────────────────────────────────────────────────────────────────
# Paths are relative to the working directory inside the container (/app)
RESUME_PATH=assets/resume.pdf
PROFILE_PATH=assets/profile.json
